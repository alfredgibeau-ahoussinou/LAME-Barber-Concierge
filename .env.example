# ── Serveur ──────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de données ───────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=blade_barber
DB_USER=postgres
DB_PASSWORD=your_password_here

# ── JWT ───────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# ── Stripe ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_COMMISSION_PERCENT=15

# ── Apple Push Notifications (APNs) ──────────────
APN_KEY_PATH=./certs/AuthKey.p8
APN_KEY_ID=YOUR_KEY_ID
APN_TEAM_ID=YOUR_TEAM_ID
APN_BUNDLE_ID=com.blade.barber
APN_PRODUCTION=false

# ── AWS S3 (photos) ───────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=eu-west-3
AWS_BUCKET_NAME=blade-barber-media

# ── Google Maps ───────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_key

# ── Sécurité ──────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
FRONTEND_URL=http://localhost:3001
