<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  À copier dans : ios/LAME/Info.plist
  (ou le nom que tu as choisi)
  
  Remplace LAME par ton nom final partout.
-->
<plist version="1.0">
<dict>

  <!-- ── Identité ──────────────────────────────────── -->
  <key>CFBundleDisplayName</key>
  <string>LAME</string>

  <key>CFBundleName</key>
  <string>LAME</string>

  <key>CFBundleIdentifier</key>
  <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>

  <key>CFBundleVersion</key>
  <string>1</string>

  <key>CFBundleShortVersionString</key>
  <string>1.0.0</string>

  <key>CFBundlePackageType</key>
  <string>APPL</string>

  <key>CFBundleSignature</key>
  <string>????</string>

  <key>CFBundleExecutable</key>
  <string>$(EXECUTABLE_NAME)</string>

  <!-- ── Fonts embarquées ──────────────────────────── -->
  <key>UIAppFonts</key>
  <array>
    <string>CormorantGaramond-Light.ttf</string>
    <string>CormorantGaramond-Regular.ttf</string>
    <string>CormorantGaramond-LightItalic.ttf</string>
    <string>DMSans-Regular.ttf</string>
    <string>DMSans-Light.ttf</string>
    <string>DMSans-Medium.ttf</string>
  </array>

  <!-- ── Permissions ───────────────────────────────── -->
  <key>NSLocationWhenInUseUsageDescription</key>
  <string>LAME utilise votre position pour trouver les barbiers proches.</string>

  <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
  <string>LAME utilise votre position 30 min avant votre RDV pour le tracking en temps réel.</string>

  <key>NSLocationAlwaysUsageDescription</key>
  <string>LAME utilise votre position en arrière-plan pour le suivi de votre barbier.</string>

  <key>NSCameraUsageDescription</key>
  <string>LAME utilise votre caméra pour votre photo de profil.</string>

  <key>NSPhotoLibraryUsageDescription</key>
  <string>LAME accède à vos photos pour votre photo de profil.</string>

  <key>NSPhotoLibraryAddUsageDescription</key>
  <string>LAME sauvegarde vos photos dans votre bibliothèque.</string>

  <key>NSFaceIDUsageDescription</key>
  <string>LAME utilise Face ID pour sécuriser vos paiements.</string>

  <key>NSContactsUsageDescription</key>
  <string>LAME accède à vos contacts pour les invitations de groupe (EVG, mariage).</string>

  <key>NSMicrophoneUsageDescription</key>
  <string>LAME utilise le micro pour l'assistance vocale.</string>

  <!-- ── Background modes ───────────────────────────── -->
  <key>UIBackgroundModes</key>
  <array>
    <string>location</string>
    <string>fetch</string>
    <string>remote-notification</string>
  </array>

  <!-- ── Deep links / URL Schemes ──────────────────── -->
  <key>CFBundleURLTypes</key>
  <array>
    <dict>
      <key>CFBundleURLName</key>
      <string>com.lame.barber</string>
      <key>CFBundleURLSchemes</key>
      <array>
        <string>lame</string>
        <string>lame-barber</string>
      </array>
    </dict>
  </array>

  <!-- ── Apparence ─────────────────────────────────── -->
  <key>UIStatusBarStyle</key>
  <string>UIStatusBarStyleLightContent</string>

  <key>UIViewControllerBasedStatusBarAppearance</key>
  <false/>

  <key>UIUserInterfaceStyle</key>
  <string>Dark</string>

  <key>UISupportedInterfaceOrientations</key>
  <array>
    <string>UIInterfaceOrientationPortrait</string>
  </array>

  <key>UISupportedInterfaceOrientations~ipad</key>
  <array>
    <string>UIInterfaceOrientationPortrait</string>
    <string>UIInterfaceOrientationPortraitUpsideDown</string>
    <string>UIInterfaceOrientationLandscapeLeft</string>
    <string>UIInterfaceOrientationLandscapeRight</string>
  </array>

  <!-- ── Sécurité réseau ────────────────────────────── -->
  <key>NSAppTransportSecurity</key>
  <dict>
    <key>NSExceptionDomains</key>
    <dict>
      <key>localhost</key>
      <dict>
        <key>NSExceptionAllowsInsecureHTTPLoads</key>
        <true/>
      </dict>
      <key>10.0.2.2</key>
      <dict>
        <key>NSExceptionAllowsInsecureHTTPLoads</key>
        <true/>
      </dict>
    </dict>
  </dict>

  <!-- ── React Native ───────────────────────────────── -->
  <key>NSAppTransportSecurity</key>
  <dict>
    <key>NSAllowsArbitraryLoads</key>
    <false/>
    <key>NSExceptionDomains</key>
    <dict>
      <key>localhost</key>
      <dict>
        <key>NSExceptionAllowsInsecureHTTPLoads</key>
        <true/>
      </dict>
    </dict>
  </dict>

</dict>
</plist>
